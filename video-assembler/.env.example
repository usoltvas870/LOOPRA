# DeepSeek AI (required for AI pipeline, optional for direct assembly)
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Content Plant root directory (auto-detected if empty)
CONTENT_PLANT_ROOT=

# Custom directories (optional — defaults to subdirs of CONTENT_PLANT_ROOT)
JOBS_DIR=
MEDIA_DIR=
SCENARIOS_DIR=
