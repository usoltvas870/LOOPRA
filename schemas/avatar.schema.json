{
  "$defs": {
    "AvatarMeta": {
      "additionalProperties": false,
      "properties": {
        "presenter_name": {
          "anyOf": [
            {
              "maxLength": 60,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Presenter Name"
        },
        "lower_third_style": {
          "anyOf": [
            {
              "enum": [
                "minimal",
                "premium",
                "soft"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lower Third Style"
        },
        "safe_zone_mode": {
          "anyOf": [
            {
              "enum": [
                "portrait_safe",
                "full_frame"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Safe Zone Mode"
        }
      },
      "title": "AvatarMeta",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Avatar-led short with text overlays designed to stay in portrait-safe zones.",
  "examples": [
    {
      "body": "This format is designed for avatar or presenter footage with lower-third text support.",
      "brand_id": "nura",
      "content_type": "avatar",
      "cta": "Get your reading in Telegram",
      "cta_handle": "@ai_nura_bot",
      "hook": "You do not need to explain yourself perfectly.",
      "meta": {
        "presenter_name": "NURA",
        "safe_zone_mode": "portrait_safe"
      },
      "title": "Sometimes the real problem is how you learned to hear yourself.",
      "voiceover": "You do not need to explain yourself perfectly. Sometimes the real problem is how you learned to hear yourself."
    }
  ],
  "properties": {
    "content_type": {
      "const": "avatar",
      "title": "Content Type",
      "type": "string"
    },
    "brand_id": {
      "maxLength": 32,
      "minLength": 2,
      "pattern": "^[a-z0-9_-]+$",
      "title": "Brand Id",
      "type": "string"
    },
    "brand": {
      "anyOf": [
        {
          "maxLength": 48,
          "minLength": 2,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Optional display override.",
      "title": "Brand"
    },
    "hook": {
      "maxLength": 80,
      "minLength": 6,
      "title": "Hook",
      "type": "string"
    },
    "title": {
      "maxLength": 140,
      "minLength": 12,
      "title": "Title",
      "type": "string"
    },
    "body": {
      "maxLength": 240,
      "minLength": 18,
      "title": "Body",
      "type": "string"
    },
    "cta": {
      "maxLength": 90,
      "minLength": 6,
      "title": "Cta",
      "type": "string"
    },
    "voiceover": {
      "maxLength": 1100,
      "minLength": 24,
      "title": "Voiceover",
      "type": "string"
    },
    "cta_handle": {
      "anyOf": [
        {
          "maxLength": 32,
          "minLength": 2,
          "pattern": "^@?[A-Za-z0-9_]+$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Cta Handle"
    },
    "cta_subtitle": {
      "anyOf": [
        {
          "maxLength": 120,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Cta Subtitle"
    },
    "cta_hint": {
      "anyOf": [
        {
          "maxLength": 60,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Cta Hint"
    },
    "theme": {
      "const": "brand_default",
      "default": "brand_default",
      "title": "Theme",
      "type": "string"
    },
    "typing_mode": {
      "default": "word",
      "enum": [
        "word",
        "char"
      ],
      "title": "Typing Mode",
      "type": "string"
    },
    "panel_style": {
      "default": "soft",
      "enum": [
        "soft",
        "clean",
        "strong",
        "premium"
      ],
      "title": "Panel Style",
      "type": "string"
    },
    "scenes": {
      "anyOf": [
        {
          "items": {
            "maxLength": 220,
            "minLength": 4,
            "type": "string"
          },
          "maxItems": 6,
          "minItems": 2,
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Optional explicit scene copy. When omitted, renderer builds scenes from hook/title/body/cta.",
      "title": "Scenes"
    },
    "meta": {
      "$ref": "#/$defs/AvatarMeta"
    }
  },
  "required": [
    "content_type",
    "brand_id",
    "hook",
    "title",
    "body",
    "cta",
    "voiceover"
  ],
  "title": "AvatarBrief",
  "type": "object",
  "x-content-plant": {
    "failure_behavior": "Fail fast. Do not render. Print a human-readable validation error.",
    "scene_structure": [
      "intro",
      "speech",
      "pullquote",
      "support",
      "cta"
    ],
    "timing_expectations_sec": {
      "cta": [
        27,
        33
      ],
      "intro": [
        0,
        3
      ],
      "pullquote": [
        12,
        21
      ],
      "speech": [
        3,
        12
      ],
      "support": [
        21,
        27
      ]
    }
  }
}