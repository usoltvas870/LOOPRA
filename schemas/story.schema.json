{
  "$defs": {
    "StoryMeta": {
      "additionalProperties": false,
      "properties": {
        "story_arc": {
          "anyOf": [
            {
              "enum": [
                "transformation",
                "mistake",
                "realization",
                "before_after"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Story Arc"
        },
        "emotional_shift": {
          "anyOf": [
            {
              "maxLength": 80,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Emotional Shift"
        }
      },
      "title": "StoryMeta",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Narrative short with setup, tension, resolution, and CTA.",
  "examples": [
    {
      "body": "When you stop performing certainty, your real voice gets stronger.",
      "brand_id": "nura",
      "content_type": "story",
      "cta": "Get your reading in Telegram",
      "cta_handle": "@ai_nura_bot",
      "hook": "I thought I had to hide this part of myself.",
      "meta": {
        "story_arc": "realization"
      },
      "title": "Then I realized it was the exact thing people trusted most."
    }
  ],
  "properties": {
    "content_type": {
      "const": "story",
      "title": "Content Type",
      "type": "string"
    },
    "brand_id": {
      "maxLength": 32,
      "minLength": 2,
      "pattern": "^[a-z0-9_-]+$",
      "title": "Brand Id",
      "type": "string"
    },
    "brand": {
      "anyOf": [
        {
          "maxLength": 48,
          "minLength": 2,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Optional display override.",
      "title": "Brand"
    },
    "hook": {
      "maxLength": 90,
      "minLength": 6,
      "title": "Hook",
      "type": "string"
    },
    "title": {
      "maxLength": 140,
      "minLength": 12,
      "title": "Title",
      "type": "string"
    },
    "body": {
      "maxLength": 340,
      "minLength": 18,
      "title": "Body",
      "type": "string"
    },
    "cta": {
      "maxLength": 90,
      "minLength": 6,
      "title": "Cta",
      "type": "string"
    },
    "voiceover": {
      "anyOf": [
        {
          "maxLength": 900,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Voiceover"
    },
    "cta_handle": {
      "anyOf": [
        {
          "maxLength": 32,
          "minLength": 2,
          "pattern": "^@?[A-Za-z0-9_]+$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Cta Handle"
    },
    "cta_subtitle": {
      "anyOf": [
        {
          "maxLength": 120,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Cta Subtitle"
    },
    "cta_hint": {
      "anyOf": [
        {
          "maxLength": 60,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Cta Hint"
    },
    "theme": {
      "const": "brand_default",
      "default": "brand_default",
      "title": "Theme",
      "type": "string"
    },
    "typing_mode": {
      "default": "word",
      "enum": [
        "word",
        "char"
      ],
      "title": "Typing Mode",
      "type": "string"
    },
    "panel_style": {
      "default": "soft",
      "enum": [
        "soft",
        "clean",
        "strong",
        "premium"
      ],
      "title": "Panel Style",
      "type": "string"
    },
    "scenes": {
      "anyOf": [
        {
          "items": {
            "maxLength": 220,
            "minLength": 4,
            "type": "string"
          },
          "maxItems": 6,
          "minItems": 2,
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Optional explicit scene copy. When omitted, renderer builds scenes from hook/title/body/cta.",
      "title": "Scenes"
    },
    "meta": {
      "$ref": "#/$defs/StoryMeta"
    }
  },
  "required": [
    "content_type",
    "brand_id",
    "hook",
    "title",
    "body",
    "cta"
  ],
  "title": "StoryBrief",
  "type": "object",
  "x-content-plant": {
    "failure_behavior": "Fail fast. Do not render. Print a human-readable validation error.",
    "scene_structure": [
      "hook",
      "setup",
      "tension",
      "resolution",
      "cta"
    ],
    "timing_expectations_sec": {
      "cta": [
        23,
        31
      ],
      "hook": [
        0,
        3
      ],
      "resolution": [
        15,
        23
      ],
      "setup": [
        3,
        8.5
      ],
      "tension": [
        8.5,
        15
      ]
    }
  }
}